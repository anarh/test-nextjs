# Copy this file to `.env.local` and fill in the values from your Supabase project.
# Supabase Dashboard -> Project Settings -> API (or "Connect" button on the top bar)

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public "anon" key (safe to expose to the browser; RLS protects your data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
